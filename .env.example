# ── Database ──
DATABASE_URL=postgres://postgres:password@localhost:5432/teamti_music
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=teamti_music

# ── Discord ──
DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# ── Media ──
MEDIA_ROOT=./media_data

USER_AGENT=TeamTI/0.1.0 (teamti@localhost)
ACOUSTID_API_KEY=your_acoustid_api_key_here
MB_FETCH_WORK_CREDITS=true
SCAN_INTERVAL_SECS=300
SMB_READ_CONCURRENCY=3
FINGERPRINT_CONCURRENCY=4
COVER_ART_CONCURRENCY=4
TAG_WRITE_CONCURRENCY=2
ENRICHMENT_CONFIDENCE_THRESHOLD=0.85
UNMATCHED_RETRY_LIMIT=3
FAILED_RETRY_LIMIT=5
DB_POOL_SIZE=10

# ── Voice ──
AUTO_LEAVE_SECS=30

# ── Search ──
# Tantivy search index directory — LOCAL disk only, not NAS.
# Fully reconstructable from PostgreSQL; safe to delete.
TANTIVY_INDEX_PATH=./search_index

# ── Pass 4: Analysis & Discovery ──
LASTFM_API_KEY=
ANALYSIS_CONCURRENCY=4
ANALYSIS_POLL_SECS=30

# ── Logging ──
RUST_LOG=info,teamti=debug
LOG_FORMAT=pretty
