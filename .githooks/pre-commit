#!/bin/sh
# Pre-commit hook: run cargo fmt and fail if code is unformatted.
# Install: this file is auto-installed by the setup script.

set -e

# Only check staged .rs files to keep the hook fast
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs' || true)

if [ -z "$STAGED_RS" ]; then
    exit 0
fi

# Run cargo fmt check
if ! cargo fmt --all -- --check 2>/dev/null; then
    echo ""
    echo "╭──────────────────────────────────────────────╮"
    echo "│  cargo fmt check failed.                     │"
    echo "│  Run 'cargo fmt --all' and stage the changes.│"
    echo "╰──────────────────────────────────────────────╯"
    echo ""
    exit 1
fi
