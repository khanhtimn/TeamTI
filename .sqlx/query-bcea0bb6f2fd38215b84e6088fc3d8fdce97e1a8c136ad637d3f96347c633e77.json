{
  "db_name": "PostgreSQL",
  "query": "SELECT p.id, p.name, p.owner_id, p.visibility,\n                    COALESCE(COUNT(pi.id), 0) AS \"track_count!\"\n             FROM playlists p\n             LEFT JOIN playlist_items pi ON pi.playlist_id = p.id\n             WHERE p.owner_id = $1\n             GROUP BY p.id\n             ORDER BY p.updated_at DESC",
