{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                ta.track_id, ta.artist_id, ta.role as \"role: ArtistRole\", ta.position,\n                a.id, a.name, a.sort_name, a.mbid, a.country, a.created_at\n            FROM track_artists ta\n            JOIN artists a ON a.id = ta.artist_id\n            WHERE ta.track_id = $1\n            ORDER BY ta.position ASC\n            ",
